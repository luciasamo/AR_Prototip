  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "M\xC1SCARAS DE LA PESTE NEGRA\n\r\n- Eran m\xE1scaras con pico usadas
    por m\xE9dicos entre los siglos XVII\u2013XVIII.\r\n- El pico llevaba hierbas
    arom\xE1ticas porque se cre\xEDa que la peste se transmit\xEDa por \u201Caires
    contaminados\u201D.\r\n- Formaban parte de un traje protector de cuero y cera
    para evitar el contacto con fluidos.\r\n- No proteg\xEDan realmente del contagio,
    pero s\xED ofrec\xEDan una barrera f\xEDsica b\xE1sica.\r\n- Hoy son un s\xEDmbolo
    hist\xF3rico de las epidemias y del miedo colectivo.\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
