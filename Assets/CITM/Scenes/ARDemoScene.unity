  m_EditorClassIdentifier: Assembly-CSharp::QuestionManager
  questions:
  - questionText: "\xBFLas m\xE1scaras de la peste negra proteg\xEDan realmente contra
      la enfermedad?"
    correctAnswer: 0
    explanation: "Se usaban por la teor\xEDa del miasma, creyendo que los malos olores
      transmit\xEDan la enfermedad."
    maskIndex: 0
  - questionText: "Las m\xE1scaras venecianas ten\xEDan una funci\xF3n ceremonial"
    correctAnswer: 1
    explanation: Se usaban principalmente en carnavales y eventos sociales.
    maskIndex: 1
  - questionText: "Las m\xE1scaras oni representan demonios de la mitolog\xEDa japonesa"
    correctAnswer: 1
    explanation: "Las m\xE1scaras oni se inspiran en criaturas demon\xEDacas del
      folclore japon\xE9s y se usan en festivales, teatro y rituales tradicionales
      para representar fuerzas sobrenaturales."
    maskIndex: 2
  - questionText: "Las m\xE1scaras masquerade se usaban originalmente con fines m\xE9dicos"
    correctAnswer: 0
    explanation: "Las m\xE1scaras masquerade se popularizaron en bailes y eventos
      sociales, especialmente en Europa, como elementos decorativos y de ocultaci\xF3n
      de identidad."
    maskIndex: 3
  - questionText: "Las m\xE1scaras tiki tienen su origen en culturas polinesias y
      est\xE1n relacionadas con deidades o ancestros"
    correctAnswer: 1
    explanation: "Las tiki masks provienen de culturas polinesias y representan figuras
      sagradas asociadas a dioses, esp\xEDritus protectores o antepasados."
    maskIndex: 4
  - questionText: "Las m\xE1scaras nepal\xEDes se utilizan exclusivamente como objetos
      decorativos sin significado cultural"
    correctAnswer: 0
    explanation: "Estas m\xE1scaras tienen un fuerte valor ritual y cultural, y se
      usan en danzas tradicionales, festivales religiosos y representaciones mitol\xF3gicas."
    maskIndex: 5
  questionText: {fileID: 1410081492}
